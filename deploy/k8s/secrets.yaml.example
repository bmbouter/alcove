# EXAMPLE secrets — copy to secrets.yaml and fill in real values.
#
# Generate a credential key:
#   openssl rand -hex 32
#
# WARNING: Do not commit secrets.yaml to version control.
apiVersion: v1
kind: Secret
metadata:
  name: alcove-secrets
  namespace: alcove
type: Opaque
stringData:
  credential-key: "CHANGE-ME-generate-with-openssl-rand-hex-32"
  database-url: "postgres://alcove:alcove@alcove-ledger:5432/alcove?sslmode=disable"
