# Alcove Bridge Configuration
# Copy this file to alcove.conf and customize it for your environment.
# Environment variables take precedence over this file.

# Database encryption key — used to encrypt all stored credentials (API keys,
# tokens, etc.) at rest with AES-256-GCM. If you change this, all previously
# stored credentials become unreadable.
# REQUIRED: You must set this to a strong, unique value before starting Bridge.
# Generate one with: openssl rand -hex 32
credential_key = change-me-to-a-strong-secret

# PostgreSQL connection URL for Ledger (session store).
database_url = postgres://alcove:alcove@localhost:5432/alcove?sslmode=disable

# NATS connection URL for Hail (message bus).
nats_url = nats://localhost:4222

# Authentication backend: "memory" (single admin, no persistence) or
# "postgres" (multi-user, persistent, recommended).
auth_backend = postgres

# HTTP listen port.
port = 8080

# Container runtime: "podman" or "kubernetes".
runtime = podman
