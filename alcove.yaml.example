# Alcove Bridge Configuration
# Environment variables take precedence over this file.

# Database encryption key for AES-256-GCM encryption of stored credentials.
# REQUIRED. Generate with: openssl rand -hex 32
database_encryption_key: change-me-to-a-strong-secret

# PostgreSQL connection URL for Ledger (session store).
database_url: postgres://alcove:alcove@localhost:5432/alcove?sslmode=disable

# NATS connection URL for Hail (message bus).
nats_url: nats://localhost:4222

# Authentication backend: "memory" or "postgres" (recommended).
auth_backend: postgres

# HTTP listen port.
port: "8080"

# Container runtime: "podman", "docker", or "kubernetes".
runtime: podman

# System LLM — powers AI features (security profile builder).
# Uncomment and configure ONE provider to enable AI features.

# Option A: Anthropic API
# system_llm:
#   provider: anthropic
#   api_key: sk-ant-...
#   model: claude-sonnet-4-20250514

# Option B: Claude Pro/Max (OAuth)
# system_llm:
#   provider: claude-oauth
#   oauth_token: <token from 'claude setup-token'>
#   model: claude-sonnet-4-20250514

# Option C: Google Vertex AI (Service Account)
# system_llm:
#   provider: google-vertex
#   service_account_json: |
#     {"type": "service_account", ...}
#   project_id: my-gcp-project
#   region: us-east5
#   model: claude-sonnet-4-20250514
