# Alcove Bridge Configuration
# Environment variables take precedence over this file.

# Database encryption key for AES-256-GCM encryption of stored credentials.
# REQUIRED. Generate with: openssl rand -hex 32
database_encryption_key: change-me-to-a-strong-secret

# PostgreSQL connection URL for Ledger (session store).
database_url: postgres://alcove:alcove@localhost:5432/alcove?sslmode=disable

# NATS connection URL for Hail (message bus).
nats_url: nats://localhost:4222

# Authentication backend: "memory" or "postgres" (recommended).
auth_backend: postgres

# HTTP listen port.
port: "8080"

# Container runtime: "podman" or "kubernetes".
runtime: podman
